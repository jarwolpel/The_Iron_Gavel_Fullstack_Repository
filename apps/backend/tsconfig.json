{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
      "typeRoots": ["./node_modules/@types", "./src"],
      "esModuleInterop": true,
      "target": "ES6",
      "module": "commonjs",
      "rootDir": "../../",
      "outDir": "./dist",
      "baseUrl": "./",
      "sourceMap": true,
      "lib": ["ESNext"],
      "paths": {
        "*": ["*"],
        "@shared/*": ["../../shared/*"]
      }
    },
    "include": ["src/**/*", "tests/**/*","../../shared/**/*"],
    "exclude": ["node_modules", "dist"]
}