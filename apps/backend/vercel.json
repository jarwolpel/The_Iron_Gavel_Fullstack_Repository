{
   "relatedProjects": ["prj_FV1PE6UorqJp9uFoPgXUxnds5JIV"],

   "headers": [
    {
        "source": "/api/(.*)",
        "headers": [
            { "key": "Access-Control-Allow-Credentials", "value": "true" },
            { "key":"Access-Control-Allow-Origin", "value":"https://the-iron-gavel-fullstack-repository.vercel.app"},
            { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
            { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
        ]
    }
   ],
   "rewrites": [
       {

           "source": "/api/(.*)",
           "destination": "/api/$1" 
       }
   ],
   "git": {
     "deploymentEnabled": {
         "*": false,
         "main": true
    }
 }
}